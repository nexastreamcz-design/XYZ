<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addon id="plugin.video.streamcatalog" name="StreamCatalog" version="8.0.0" provider-name="StreamCatalog">
    <requires>
        <import addon="xbmc.python" version="3.0.0"/>
    </requires>
    <extension point="xbmc.python.pluginsource" library="main.py">
        <provides>video</provides>
    </extension>
    <extension point="xbmc.addon.metadata">
        <summary lang="cs_CZ">StreamCatalog – TMDB katalog, WebShare, FastShare a Hellspy</summary>
        <description lang="cs_CZ">Prohlížení filmů a seriálů přes TMDB, vyhledávání streamů na WebShare a FastShare, volitelně Hellspy. Historie a oblíbené pouze lokálně v Kodi.</description>
        <platform>all</platform>
        <license>GPL-3.0</license>
        <assets>
            <icon>icon.png</icon>
            <fanart>fanart.jpg</fanart>
        </assets>
    </extension>
</addon>
